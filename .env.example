# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAPS_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Payment Gateways (Placeholders)
ESEWA_MERCHANT_ID=your-esewa-merchant-id
