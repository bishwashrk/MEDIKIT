# Django
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-use-strong-key
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
DB_NAME=medikit_db
DB_USER=root
DB_PASSWORD=medikit_password
DB_HOST=db
DB_PORT=3306

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
