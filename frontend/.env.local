# MediKit Frontend Environment Variables

# Backend API URL (Django server)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# App settings
NEXT_PUBLIC_APP_NAME=MediKit
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default map center (Kathmandu, Nepal)
NEXT_PUBLIC_DEFAULT_LAT=27.7172
NEXT_PUBLIC_DEFAULT_LNG=85.3240
